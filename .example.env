# Required for blog planning and writing
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
# Recommended for web research mode
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith tracing
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=deep-blog-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image
DEEP_BLOG_AGENT_DEFAULT_ENABLE_RESEARCH=true
DEEP_BLOG_AGENT_DEFAULT_ENABLE_IMAGES=true
DEEP_BLOG_AGENT_OUTPUT_DIR=outputs
DEEP_BLOG_AGENT_LEGACY_BLOGS_DIR=.
DEEP_BLOG_AGENT_PRICING_LABEL=Application defaults
DEEP_BLOG_AGENT_OPENAI_INPUT_PRICE_PER_1M_TOKENS_USD=0.40
DEEP_BLOG_AGENT_OPENAI_OUTPUT_PRICE_PER_1M_TOKENS_USD=1.60
DEEP_BLOG_AGENT_TAVILY_SEARCH_PRICE_USD=0.005
DEEP_BLOG_AGENT_GOOGLE_IMAGE_PRICE_USD=0.04


